{
  "name": "openwrt-mwan3-dashboard",
  "version": "1.0.0",
  "description": "لوحة تحكم احترافية لإدارة MWAN3 ودمج خطوط الإنترنت في OpenWrt",
  "main": "backend/server.js",
  "type": "module",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "nodemon backend/server.js",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "echo 'Backend ready'",
    "build:frontend": "cd frontend && npm run build",
    "test": "jest",
    "lint": "eslint ."
  },
  "keywords": [
    "OpenWrt",
    "MWAN3",
    "Load Balancing",
    "QoS",
    "Dashboard",
    "Arabic"
  ],
  "author": "BakiAbaad",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "axios": "^1.4.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "node-ssh": "^13.1.0",
    "socket.io": "^4.7.2",
    "sqlite3": "^5.1.6",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "jest": "^29.6.2",
    "eslint": "^8.45.0"
  }
}
